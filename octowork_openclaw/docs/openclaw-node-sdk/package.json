{
  "name": "@openclaw/node-sdk",
  "version": "0.1.0",
  "description": "Node.js SDK for OpenClaw gateway-node protocol",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist/test/*.test.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.6.0"
  },
  "license": "MIT",
  "keywords": ["openclaw", "gateway", "node", "websocket", "ed25519"]
}
